<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="32dp"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:background="@drawable/bg_futuristic">

    <!--App Title-->
    <TextView
        android:id="@+id/textviewTitle"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:text="@string/life_hack_or_urban_myth"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginBottom="20dp"/>

    <!--Description-->
    <TextView
        android:id="@+id/textviewDescription"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:text="@string/test_your_knowledge_and_learn_which_life_hacks_are_real_and_which_life_hacks_are_real_and_which_are_just_myths"
        android:textSize="18sp"
        android:textColor="@color/black"
        android:gravity="center"
        android:layout_marginBottom="40dp"/>

    <!--Start Button-->
    <Button
        android:id="@+id/startButton"
        android:layout_width="200dp"
        android:layout_height="60dp"
        android:text="@string/start"
        android:textStyle="bold"
        android:textSize="18sp"
        android:backgroundTint="#00E5FF"
        android:textColor="#000000"/>

</LinearLayout>